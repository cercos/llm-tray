{
  "name": "llm-tray",
  "version": "1.0.5",
  "main": "main.js",
  "description": "Tray launcher for multiple LLM web apps",
  "author": "derek",
  "scripts": {
    "start": "electron .",
    "dist": "rm -rf dist && electron-builder --win --linux"
  },
  "build": {
    "appId": "com.derek.llmtray",
    "productName": "LLM Tray",
    "files": [
      "main.js",
      "preload.js",
      "preload-guest.js",
      "oauth.js",
      "views/**/*",
      "assets/**/*",
      "icon.png",
      "package.json"
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility",
      "icon": "build/icons",
      "maintainer": "derek",
      "synopsis": "Tray launcher for multiple LLM web apps",
      "desktop": {
        "entry": {
          "Name": "LLM Tray",
          "Comment": "Tray launcher for LLMs",
          "Icon": "llm-tray",
          "StartupWMClass": "LLM Tray"
        }
      }
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icons/256x256.png"
    }
  },
  "devDependencies": {
    "electron": "^31.3.1",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "node-fetch": "^2.7.0"
  }
}
